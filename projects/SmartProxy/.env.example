# SmartProxy Environment Variables
# Copy this file to .env and fill in the values

# The API Key for xAI (Grok)
GROK_API_KEY=your_grok_api_key_here

# The API Key for Anthropic (Claude)
CLAUDE_API_KEY=your_claude_api_key_here

# The API Key for DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: List of DeepSeek models to expose (comma-separated)
# DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# Optional: Timeout in seconds for DeepSeek API calls (default: 120)
# DEEPSEEK_TIMEOUT=120

# The API Key for Fireworks AI
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Optional: List of Fireworks models to expose (comma-separated)
# Model IDs use the accounts/fireworks/models/ prefix
# FIREWORKS_MODELS=accounts/fireworks/models/deepseek-v3p2,accounts/fireworks/models/mixtral-8x22b-instruct,accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/gpt-oss-20b,accounts/fireworks/models/kimi-k2-instruct-0905

# Optional: Timeout in seconds for Fireworks API calls (default: 120)
# FIREWORKS_TIMEOUT=120

# The token required by the Rails app to authenticate with this proxy
PROXY_AUTH_TOKEN=your_secure_proxy_token_here

# Optional: List of Claude models to expose (comma-separated)
# CLAUDE_MODELS=claude-3-5-sonnet-latest,claude-3-opus-latest

# Optional: Port for the Sinatra server (default: 4567)
SMART_PROXY_PORT=4567
