<%= render ::Layouts::ApplicationLayout.new(
  title: @scene.name,
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(limit: 15),
  sidebar_title: "Recent Activity"
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: 'Dashboard', path: root_path },
          { label: 'Scenes', path: scenes_path },
          { label: @scene.name, path: nil }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2"><%= @scene.name %></h1>
      </div>

      <div class="flex gap-3">
        <button
          type="button"
          class="btn btn-primary"
          data-controller="scene"
          data-scene-id-value="<%= @scene.id %>"
          data-action="click->scene#execute">
          <span data-scene-target="buttonText">Execute Scene</span>
          <span data-scene-target="spinner" class="hidden">
            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </span>
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Scene Details -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h2 class="card-title text-lg">Details</h2>
          <div class="space-y-2">
            <p><strong>Home:</strong> <%= @scene.home.name %></p>
            <p><strong>Accessories:</strong> <%= @scene.accessories.count %></p>
            <p><strong>UUID:</strong> <code class="bg-base-200 px-2 py-1 rounded text-sm"><%= @scene.uuid %></code></p>
            <p><strong>Created:</strong> <%= l(@scene.created_at, format: :long) %></p>
            <p><strong>Updated:</strong> <%= l(@scene.updated_at, format: :long) %></p>
          </div>
        </div>
      </div>

      <!-- Scene Accessories -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h2 class="card-title text-lg">Accessories</h2>
          <% if @scene.accessories.empty? %>
            <p class="text-base-content/60">No accessories associated with this scene.</p>
          <% else %>
            <ul class="space-y-2">
              <% @scene.accessories.each do |accessory| %>
                <li class="flex items-center gap-2 py-2 border-b border-base-200 last:border-0">
                  <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                  </div>
                  <span class="font-medium"><%= accessory.name %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Execution History -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-lg">Execution History</h2>
        <% if @execution_history.empty? %>
          <p class="text-base-content/60">No execution history for this scene.</p>
        <% else %>
          <div class="overflow-x-auto">
            <table class="table w-full">
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Status</th>
                  <th>Latency</th>
                  <th>Source</th>
                  <th>Error</th>
                </tr>
              </thead>
              <tbody>
                <% @execution_history.each do |event| %>
                  <tr>
                    <td><%= l(event.created_at, format: :short) %></td>
                    <td>
                      <% if event.success %>
                        <span class="badge badge-success">Success</span>
                      <% else %>
                        <span class="badge badge-error">Failed</span>
                      <% end %>
                    </td>
                    <td><%= event.latency_ms %>ms</td>
                    <td><%= event.source %></td>
                    <td><%= event.error_message.presence || '-' %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Feedback area for inline execute -->
    <div data-scene-target="feedback" class="hidden"></div>
  </div>
<% end %>
