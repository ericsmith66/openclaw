<%= render ::Layouts::ApplicationLayout.new(
  title: "Your Homes",
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(limit: 15)
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: "Eureka", path: root_path },
          { label: "Homes", path: nil }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2">Your Homes</h1>
        <p class="text-base-content/60 mt-1">Manage and monitor your HomeKit-enabled properties.</p>
      </div>
      
      <div class="flex gap-2">
        <button class="btn btn-outline btn-sm gap-2">
          <%= lucide_icon("plus", size: 16) %>
          Add Home
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 2xl:grid-cols-3 gap-6">
      <% if @homes.any? %>
        <% @homes.each do |home| %>
          <%= render Homes::CardComponent.new(home: home) %>
        <% end %>
      <% else %>
        <div class="col-span-full py-24 text-center bg-base-100 rounded-3xl border-2 border-dashed border-base-200">
           <div class="bg-base-200 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-base-content/30">
             <%= lucide_icon("home", size: 32) %>
           </div>
           <h3 class="text-lg font-bold">No homes detected</h3>
           <p class="text-sm opacity-40 mt-1">Connect your HomeKit bridge to start monitoring.</p>
           <%= button_to "Run Initial Sync", sync_path, method: :post, class: "btn btn-primary mt-6" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
