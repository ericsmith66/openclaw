<%= render ::Layouts::ApplicationLayout.new(
  title: "Favorites",
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(limit: 15),
  sidebar_title: "Recent Activity"
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: 'Dashboard', path: root_path },
          { label: 'Favorites', path: nil }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2">Favorites</h1>
        <p class="text-base-content/60 mt-1">Quick access to your starred accessories. Drag to reorder.</p>
      </div>
    </div>

    <% if @controllable_accessories.empty? %>
      <div class="text-center py-12">
        <div class="text-6xl mb-4">⭐</div>
        <h2 class="text-2xl font-semibold mb-2">No controllable accessories</h2>
        <p class="text-base-content/60">Accessories with writable controls will appear here once synced.</p>
      </div>
    <% else %>
      <%= render Dashboards::FavoritesComponent.new(
        accessories: @controllable_accessories,
        favorites: @favorites
      ) %>
    <% end %>
  </div>
<% end %>
