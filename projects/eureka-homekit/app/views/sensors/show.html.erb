<%= render ::Layouts::ApplicationLayout.new(
  title: @sensor.display_name,
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(scope: @sensor.events, limit: 15),
  sidebar_title: "#{@sensor.accessory.name} Activity"
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: "Eureka", url: root_path },
          { label: "Sensors", url: sensors_path },
          { label: @sensor.accessory.name }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2"><%= @sensor.accessory.name %></h1>
        <p class="text-base-content/60 mt-1"><%= @sensor.characteristic_type %> detail and history.</p>
      </div>
      
      <div class="flex gap-2">
        <button class="btn btn-outline btn-sm gap-2">
          <%= lucide_icon("star", size: 16) %>
          Favorite
        </button>
        <button class="btn btn-primary btn-sm gap-2 shadow-sm">
          <%= lucide_icon("bell", size: 16) %>
          Set Alert
        </button>
      </div>
    </div>

    <%= render Sensors::DetailComponent.new(
      sensor: @sensor,
      events: @events,
      time_range: @time_range
    ) %>
  </div>
<% end %>
