<%= render ::Layouts::ApplicationLayout.new(
  title: "Sensors Dashboard",
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(limit: 15)
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: "Eureka", url: root_path },
          { label: "Sensors" }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2">Sensors Dashboard</h1>
        <p class="text-base-content/60 mt-1">Monitoring <%= @sensors.size %> sensors across all properties.</p>
      </div>
      
      <div class="flex gap-2">
        <div class="dropdown dropdown-end">
          <div tabindex="0" role="button" class="btn btn-outline btn-sm gap-2">
            <%= lucide_icon("filter", size: 16) %>
            Filter
          </div>
          <form action="<%= sensors_path %>" method="get" tabindex="0" class="dropdown-content z-[1] menu p-4 shadow-xl bg-base-100 rounded-box w-72 border border-base-200 mt-2 space-y-4">
            <div class="form-control">
              <label class="label"><span class="label-text font-bold">Status</span></label>
              <select name="status" class="select select-bordered select-sm">
                <option value="">All Statuses</option>
                <option value="online" <%= 'selected' if params[:status] == 'online' %>>Active</option>
                <option value="offline" <%= 'selected' if params[:status] == 'offline' %>>Offline</option>
                <option value="low_battery" <%= 'selected' if params[:status] == 'low_battery' %>>Low Battery</option>
              </select>
            </div>
            
            <div class="form-control">
              <label class="label"><span class="label-text font-bold">Type</span></label>
              <select name="type" class="select select-bordered select-sm">
                <option value="">All Types</option>
                <% Sensor.pluck(:characteristic_type).uniq.sort.each do |type| %>
                  <option value="<%= type %>" <%= 'selected' if params[:type] == type %>><%= type %></option>
                <% end %>
              </select>
            </div>

            <button type="submit" class="btn btn-primary btn-sm w-full">Apply Filters</button>
            <a href="<%= sensors_path %>" class="btn btn-ghost btn-xs w-full">Clear All</a>
          </form>
        </div>
      </div>
    </div>

    <%= render Sensors::AlertBannerComponent.new(alerts: @alerts) %>

    <% if @grouped_sensors.any? %>
      <% @grouped_sensors.each do |type, sensors| %>
        <section class="space-y-4">
          <div class="flex items-center justify-between border-b border-base-200 pb-2">
            <h2 class="text-lg font-bold flex items-center gap-2">
              <span class="opacity-50 font-medium"><%= type %></span>
              <span class="badge badge-ghost badge-sm"><%= sensors.size %></span>
            </h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            <% sensors.each do |sensor| %>
              <%= render Sensors::CardComponent.new(sensor: sensor) %>
            <% end %>
          </div>
        </section>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-24 px-6 text-center bg-base-100 rounded-3xl border-2 border-dashed border-base-200 shadow-sm">
        <div class="bg-base-200 p-6 rounded-full mb-6">
          <%= lucide_icon("search-x", size: 48, class: "opacity-20") %>
        </div>
        <h3 class="text-xl font-bold">No sensors found</h3>
        <p class="text-base-content/50 mt-2 max-w-md mx-auto">We couldn't find any sensors matching your current filters. Try adjusting your search or filter criteria.</p>
        <div class="mt-8">
          <a href="<%= sensors_path %>" class="btn btn-primary">Clear all filters</a>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
