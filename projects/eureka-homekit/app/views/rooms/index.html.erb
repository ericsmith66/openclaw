<%= render ::Layouts::ApplicationLayout.new(
  title: "All Rooms",
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(limit: 15)
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: "Eureka", path: root_path },
          { label: "Rooms", path: nil }
        ]) %>
        <h1 class="text-3xl font-bold tracking-tight mt-2">All Rooms</h1>
        <p class="text-base-content/60 mt-1">Showing all rooms across all connected homes.</p>
      </div>

      <div class="flex gap-2">
        <div class="join border border-base-200 p-0.5 rounded-lg bg-base-100">
          <%= link_to "Grid", rooms_path, class: "btn btn-ghost btn-xs join-item #{params[:view] != 'list' ? 'btn-active' : ''}" %>
          <%= link_to "List", rooms_path(view: 'list'), class: "btn btn-ghost btn-xs join-item #{params[:view] == 'list' ? 'btn-active' : ''}" %>
        </div>
      </div>
    </div>

    <div class="bg-base-100 p-4 rounded-2xl border border-base-200 shadow-sm">
      <%= form_with url: rooms_path, method: :get, class: "flex flex-wrap gap-4 items-center" do |f| %>
        <div class="relative flex-1 min-w-[200px]">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-base-content/30">
            <%= lucide_icon("search", size: 16) %>
          </div>
          <%= f.text_field :search, value: params[:search], placeholder: "Search rooms...", class: "input input-bordered w-full pl-10 h-10 bg-base-200/50 focus:bg-base-100" %>
        </div>
        
        <div class="flex items-center gap-2">
          <label class="label cursor-pointer gap-2">
            <%= f.check_box :has_sensors, checked: params[:has_sensors], class: "checkbox checkbox-primary checkbox-sm" %>
            <span class="label-text text-xs font-bold uppercase tracking-wider opacity-60">Has Sensors</span>
          </label>
        </div>

        <%= f.submit "Filter", class: "btn btn-primary btn-sm px-6" %>
        <% if params[:search].present? || params[:has_sensors].present? %>
          <%= link_to "Clear", rooms_path, class: "btn btn-ghost btn-sm" %>
        <% end %>
      <% end %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% if @rooms.any? %>
        <% @rooms.each do |room| %>
          <%= render Rooms::CardComponent.new(room: room) %>
        <% end %>
      <% else %>
        <div class="col-span-full py-24 text-center bg-base-100 rounded-3xl border-2 border-dashed border-base-200">
           <h3 class="text-lg font-bold">No rooms found</h3>
           <p class="text-sm opacity-40 mt-1">Try adjusting your filters or search terms.</p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
