<%= render ::Layouts::ApplicationLayout.new(
  title: @room.name,
  homes: current_homes,
  grouped_events: HomekitEvent.recent_grouped(scope: @room.homekit_events, limit: 15),
  sidebar_title: "#{@room.name} Activity"
) do %>
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <%= render Shared::BreadcrumbComponent.new(items: [
          { label: "Eureka", path: root_path },
          { label: "Rooms", path: rooms_path },
          { label: @room.name, path: nil }
        ]) %>
        <div class="flex items-center gap-3 mt-2">
          <div class="bg-primary/10 text-primary p-2 rounded-xl">
             <%# Reusing the icon logic from the card component would be better as a helper, but for now we'll just use a generic one or repeat the logic if needed. Using 'door-open' as default. %>
             <%= lucide_icon("door-open", size: 24) %>
          </div>
          <h1 class="text-3xl font-bold tracking-tight"><%= @room.name %></h1>
        </div>
        <p class="text-base-content/60 mt-1">
          Part of <%= link_to @room.home.name, home_path(@room.home), class: "text-primary hover:underline font-semibold" %>
        </p>
      </div>
      
      <div class="flex gap-2">
        <button class="btn btn-outline btn-sm gap-2">
          <%= lucide_icon("settings", size: 16) %>
          Room Settings
        </button>
      </div>
    </div>

    <%= render Rooms::DetailComponent.new(
      room: @room,
      sensors: @sensors,
      other_accessories: @other_accessories
    ) %>
  </div>
<% end %>
