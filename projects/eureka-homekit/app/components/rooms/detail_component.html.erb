<div class="space-y-8">
  <div class="bg-base-100 rounded-3xl p-6 border border-base-200 shadow-sm">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% room_status_items.each do |item| %>
        <div class="flex flex-col">
          <span class="text-[10px] font-bold uppercase tracking-widest opacity-40 mb-1"><%= item[:label] %></span>
          <div class="flex items-center gap-2">
            <% if item[:status] %>
              <div class="w-2 h-2 rounded-full bg-<%= item[:status] %>"></div>
            <% end %>
            <span class="text-xl font-bold tracking-tight"><%= item[:value] %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-bold tracking-tight">Active Sensors</h3>
        <div class="join border border-base-200 p-0.5 rounded-lg bg-base-100">
          <button class="btn btn-ghost btn-xs join-item">All</button>
          <button class="btn btn-ghost btn-xs join-item">Security</button>
          <button class="btn btn-ghost btn-xs join-item">Climate</button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% if sensors.any? %>
          <% sensors.each do |sensor| %>
            <div class="bg-base-100 p-4 rounded-2xl border border-base-200 shadow-sm flex items-center justify-between group hover:border-primary transition-colors">
              <div class="flex items-center gap-4">
                <div class="bg-base-200 p-2.5 rounded-xl text-base-content/50 group-hover:bg-primary group-hover:text-primary-content transition-colors">
                  <%= helpers.lucide_icon("activity", size: 20) %>
                </div>
                <div>
                  <p class="text-sm font-bold truncate max-w-[150px]"><%= sensor.characteristic_type %></p>
                  <p class="text-[10px] opacity-50 font-bold uppercase tracking-wider"><%= sensor.accessory.name %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-lg font-mono font-bold"><%= sensor.formatted_value %></p>
                <p class="text-[10px] opacity-40 font-medium italic"><%= time_ago_in_words(sensor.last_updated_at || Time.current) %> ago</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="col-span-full py-12 text-center bg-base-200/20 border-2 border-dashed border-base-200 rounded-3xl">
             <p class="text-sm opacity-40 italic">No sensors found in this room</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="space-y-6" data-controller="favorites">
      <h3 class="text-xl font-bold tracking-tight">Controls</h3>

      <% if controllable_accessories.size > 1 %>
        <%= render Controls::BatchControlComponent.new(accessories: controllable_accessories) %>
      <% end %>

      <div class="space-y-3">
        <% if has_controllable_accessories? %>
          <% controllable_accessories.each do |accessory| %>
            <%= render Controls::AccessoryControlComponent.new(accessory: accessory, compact: true) %>
          <% end %>
        <% else %>
           <div class="py-12 text-center bg-base-200/20 border-2 border-dashed border-base-200 rounded-3xl">
             <p class="text-sm opacity-40 italic">No controllable accessories</p>
           </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
