<div class="space-y-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
      <!-- Activity Chart Placeholder -->
      <div class="bg-base-100 rounded-3xl p-8 border border-base-200 shadow-sm min-h-[400px] flex flex-col">
         <div class="flex items-center justify-between mb-8">
           <h2 class="text-xl font-bold tracking-tight">Activity History</h2>
           <div class="join border border-base-200 p-0.5 rounded-lg">
             <%= link_to "24h", sensor_path(@sensor, time_range: "24h"), class: "btn btn-ghost btn-xs join-item #{@time_range == '24h' ? 'btn-active' : ''}" %>
             <%= link_to "7d", sensor_path(@sensor, time_range: "7d"), class: "btn btn-ghost btn-xs join-item #{@time_range == '7d' ? 'btn-active' : ''}" %>
             <%= link_to "30d", sensor_path(@sensor, time_range: "30d"), class: "btn btn-ghost btn-xs join-item #{@time_range == '30d' ? 'btn-active' : ''}" %>
           </div>
         </div>
         <div class="flex-1 flex flex-col items-center justify-center border-2 border-dashed border-base-200 rounded-2xl bg-base-200/20 overflow-hidden">
            <% if @events.any? %>
              <%= render Charts::ActivityChartComponent.new(sensor: @sensor, events: @events, time_range: @time_range) %>
            <% else %>
              <div class="text-center">
                <%= helpers.lucide_icon("line-chart", size: 48, class: "mx-auto opacity-10 mb-4") %>
                <p class="text-sm opacity-40 font-medium">No activity data for this period</p>
                <p class="text-[10px] opacity-30 mt-1 uppercase font-bold">Try selecting a different time range</p>
              </div>
            <% end %>
         </div>
      </div>

      <!-- Recent Events -->
      <div class="bg-base-100 rounded-3xl border border-base-200 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-base-200 flex items-center justify-between">
          <h2 class="text-xl font-bold tracking-tight">Recent Events</h2>
          <span class="badge badge-ghost badge-sm font-bold"><%= @events.count %> Entries</span>
        </div>
        <div class="overflow-x-auto">
          <table class="table table-md">
            <thead>
              <tr class="bg-base-200/30">
                <th class="text-[10px] uppercase font-bold opacity-50">Timestamp</th>
                <th class="text-[10px] uppercase font-bold opacity-50">Event Type</th>
                <th class="text-[10px] uppercase font-bold opacity-50">Value</th>
                <th class="text-[10px] uppercase font-bold opacity-50 text-right">Details</th>
              </tr>
            </thead>
            <tbody>
              <% if @events.any? %>
                <% @events.each do |event| %>
                  <tr class="hover:bg-base-200/50 transition-colors">
                    <td class="font-mono text-xs opacity-70">
                      <%= event.timestamp.strftime("%Y-%m-%d %H:%M:%S") %>
                    </td>
                    <td>
                      <span class="badge badge-ghost badge-xs font-bold uppercase"><%= event.event_type %></span>
                    </td>
                    <td>
                      <span class="font-bold"><%= helpers.formatted_event_value(event) %></span>
                    </td>
                    <td class="text-right">
                       <button class="btn btn-ghost btn-xs">Payload</button>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="4" class="text-center py-12 opacity-40 italic">No events found for this time range.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <!-- Sensor Stats -->
      <div class="bg-base-100 rounded-3xl p-6 border border-base-200 shadow-sm space-y-6">
        <div class="flex items-center gap-4">
          <div class="p-4 rounded-2xl bg-primary/10 text-primary">
            <%= helpers.lucide_icon(type_icon, size: 32) %>
          </div>
          <div>
            <h2 class="text-lg font-bold truncate"><%= @sensor.accessory.name %></h2>
            <p class="text-xs opacity-50 font-bold uppercase tracking-wider"><%= @sensor.characteristic_type %></p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="bg-base-200/50 rounded-2xl p-4">
            <span class="text-[10px] opacity-40 uppercase font-bold block mb-1">Current Value</span>
            <span class="text-2xl font-black">
              <%= @sensor.formatted_value %>
            </span>
          </div>
          <div class="bg-base-200/50 rounded-2xl p-4">
            <span class="text-[10px] opacity-40 uppercase font-bold block mb-1">Status</span>
            <%= render Shared::StatusBadgeComponent.new(status: @sensor.offline? ? :offline : :online, size: :sm) %>
          </div>
        </div>

        <div class="space-y-4 pt-4 border-t border-base-200">
          <div class="flex justify-between items-center text-sm">
            <span class="opacity-50">Room</span>
            <span class="font-bold"><%= @sensor.room.name %></span>
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="opacity-50">Home</span>
            <span class="font-bold"><%= @sensor.home.name %></span>
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="opacity-50">Last Updated</span>
            <span class="font-bold"><%= @sensor.last_updated_at ? time_ago_in_words(@sensor.last_updated_at) + " ago" : "Never" %></span>
          </div>
        </div>
      </div>

      <!-- Metadata -->
      <div class="bg-base-100 rounded-3xl p-6 border border-base-200 shadow-sm">
        <h3 class="text-xs font-bold uppercase tracking-widest opacity-40 mb-6">Device Metadata</h3>
        <div class="space-y-4">
          <div class="space-y-1">
            <span class="text-[10px] opacity-40 uppercase font-bold block">Characteristic UUID</span>
            <span class="text-xs font-mono break-all opacity-70"><%= @sensor.characteristic_uuid %></span>
          </div>
          <div class="space-y-1">
            <span class="text-[10px] opacity-40 uppercase font-bold block">Service Type</span>
            <span class="text-xs opacity-70"><%= @sensor.service_type %></span>
          </div>
          <div class="flex items-center gap-6 pt-2">
             <div class="flex items-center gap-2">
                <div class="badge <%= @sensor.supports_events ? 'badge-success' : 'badge-ghost' %> badge-xs"></div>
                <span class="text-[10px] font-bold uppercase opacity-50">Events</span>
             </div>
             <div class="flex items-center gap-2">
                <div class="badge <%= @sensor.is_writable ? 'badge-info' : 'badge-ghost' %> badge-xs"></div>
                <span class="text-[10px] font-bold uppercase opacity-50">Writable</span>
             </div>
          </div>
        </div>
      </div>
      
      <!-- Battery if applicable -->
      <% if @sensor.characteristic_type == "Battery Level" || @sensor.accessory.sensors.battery_level.any? %>
        <% battery_sensor = @sensor.characteristic_type == "Battery Level" ? @sensor : @sensor.accessory.sensors.battery_level.first %>
        <div class="bg-base-100 rounded-3xl p-6 border border-base-200 shadow-sm">
          <h3 class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">Battery Health</h3>
          <%= render Sensors::BatteryIndicatorComponent.new(level: battery_sensor.current_value) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
