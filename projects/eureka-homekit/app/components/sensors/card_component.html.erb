    <div id="sensor-<%= @sensor.id %>" class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-all group">
  <div class="card-body p-5">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 rounded-xl bg-<%= status_color %>/10 text-<%= status_color %>">
        <%= helpers.lucide_icon(type_icon, size: 20) %>
      </div>
      <div class="flex flex-col items-end">
        <%= render Shared::StatusBadgeComponent.new(
          status: @sensor.offline? ? :offline : :online,
          size: :xs,
          pulse: @sensor.active?
        ) %>
        <% if @sensor.last_updated_at %>
          <span class="text-[10px] opacity-40 font-medium uppercase mt-1">
            <%= time_ago_in_words(@sensor.last_updated_at) %> ago
          </span>
        <% end %>
      </div>
    </div>

    <div class="mb-4">
      <h3 class="text-sm font-bold truncate group-hover:text-primary transition-colors">
        <%= @sensor.accessory.name %>
      </h3>
      <p class="text-[10px] opacity-50 uppercase font-bold tracking-wider mt-0.5">
        <%= @sensor.characteristic_type %>
      </p>
    </div>

    <div class="flex items-baseline gap-1">
      <span class="text-2xl font-black tracking-tight">
        <%= @sensor.formatted_value %>
      </span>
    </div>

    <div class="card-actions justify-end mt-4 pt-4 border-t border-base-200">
      <%= link_to sensor_path(@sensor), class: "btn btn-ghost btn-xs gap-1 opacity-50 hover:opacity-100" do %>
        View Details
        <%= helpers.lucide_icon("chevron-right", size: 12) %>
      <% end %>
    </div>
  </div>
</div>
