<div class="floorplan-viewer relative bg-base-200 rounded-box overflow-hidden flex-1 w-full border border-base-300"
     style="min-height: 600px; display: flex; flex-direction: column;"
     data-controller="floorplan-viewer"
     data-floorplan-viewer-active-id-value="<%= @active_floorplan&.id %>"
     data-floorplan-viewer-home-id-value="<%= @home.id %>">

  <!-- Level Switcher -->
  <% if @floorplans.count > 1 %>
    <div class="absolute top-4 left-4 z-40 join shadow-lg">
      <% @floorplans.each do |fp| %>
        <button class="join-item btn btn-sm <%= fp == @active_floorplan ? 'btn-primary' : 'btn-ghost bg-base-100' %>"
                data-action="click->floorplan-viewer#switchLevel"
                data-floorplan-id="<%= fp.id %>">
          <%= fp.name %>
        </button>
      <% end %>
    </div>
  <% end %>

  <!-- Zoom Controls -->
  <div class="absolute bottom-4 right-4 z-40 flex flex-col gap-2">
    <button class="btn btn-circle btn-sm btn-ghost bg-base-100 shadow-md" data-action="click->floorplan-viewer#zoomIn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
    </button>
    <button class="btn btn-circle btn-sm btn-ghost bg-base-100 shadow-md" data-action="click->floorplan-viewer#zoomOut">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
      </svg>
    </button>
    <button class="btn btn-circle btn-sm btn-ghost bg-base-100 shadow-md" data-action="click->floorplan-viewer#resetZoom">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
    </button>
  </div>

  <!-- Loading State -->
  <div data-floorplan-viewer-target="loading" class="absolute inset-0 flex items-center justify-center bg-base-200 z-20 transition-opacity duration-300">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <!-- SVG Container -->
  <div data-floorplan-viewer-target="container" class="w-full h-full flex items-center justify-center cursor-grab active:cursor-grabbing">
    <!-- SVG will be injected here -->
  </div>

  <!-- Labels Overlay -->
  <div data-floorplan-viewer-target="overlay" 
       class="absolute inset-0 pointer-events-none z-50"
       style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1000;">
    <!-- Labels will be positioned here -->
  </div>

  <!-- Tooltip / Info Panel (Optional) -->
  <% if params[:debug].to_s == '1' %>
    <div data-floorplan-viewer-target="info" class="absolute top-4 right-4 bg-base-100 p-3 rounded-lg shadow-xl border border-base-300 hidden z-40 min-w-[200px]" style="display: none;">
      <h3 class="font-bold text-lg mb-1" data-floorplan-viewer-target="roomName">Room Name</h3>
      <div class="divider my-1"></div>
      <div data-floorplan-viewer-target="sensorData" class="space-y-1">
        <!-- Sensor data injected here -->
      </div>
    </div>
  <% end %>
</div>
