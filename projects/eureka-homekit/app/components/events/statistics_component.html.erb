<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="bg-base-100 rounded-2xl p-6 border border-base-200 shadow-sm">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-bold uppercase tracking-widest opacity-40"><%= range_label %> Total</span>
      <div class="p-2 bg-primary/10 text-primary rounded-lg">
        <%= helpers.lucide_icon("activity", size: 16) %>
      </div>
    </div>
    <div class="flex items-baseline gap-2">
      <span class="text-2xl font-bold tracking-tight"><%= number_with_delimiter(@stats[:total]) %></span>
      <span class="text-[10px] opacity-40 font-bold uppercase">Events</span>
    </div>
  </div>

  <div class="bg-base-100 rounded-2xl p-6 border border-base-200 shadow-sm">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-bold uppercase tracking-widest opacity-40">Sensor Updates</span>
      <div class="p-2 bg-info/10 text-info rounded-lg">
        <%= helpers.lucide_icon("signal", size: 16) %>
      </div>
    </div>
    <div class="flex items-baseline gap-2">
      <span class="text-2xl font-bold tracking-tight"><%= number_with_delimiter(@stats[:sensor_events]) %></span>
      <span class="text-[10px] opacity-40 font-bold uppercase">
        <%= @stats[:total] > 0 ? ((@stats[:sensor_events].to_f / @stats[:total]) * 100).round(1) : 0 %>%
      </span>
    </div>
  </div>

  <div class="bg-base-100 rounded-2xl p-6 border border-base-200 shadow-sm">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-bold uppercase tracking-widest opacity-40">Througput</span>
      <div class="p-2 bg-success/10 text-success rounded-lg">
        <%= helpers.lucide_icon("zap", size: 16) %>
      </div>
    </div>
    <div class="flex items-baseline gap-2">
      <span class="text-2xl font-bold tracking-tight"><%= @stats[:events_per_minute] %></span>
      <span class="text-[10px] opacity-40 font-bold uppercase">EPM</span>
    </div>
  </div>
</div>
