<div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-all group overflow-hidden">
  <div class="p-6">
    <div class="flex justify-between items-start mb-6">
      <div class="flex items-center gap-3">
        <div class="bg-primary/10 text-primary p-2.5 rounded-xl group-hover:bg-primary group-hover:text-primary-content transition-colors">
          <%= helpers.lucide_icon("home", size: 24) %>
        </div>
        <div>
          <h3 class="text-xl font-bold tracking-tight"><%= home.name %></h3>
          <div class="flex items-center gap-2 mt-0.5">
            <%= render Shared::StatusBadgeComponent.new(status: sync_status, size: :sm) %>
            <span class="text-[10px] opacity-40 font-bold uppercase tracking-wider">Last Sync: <%= last_sync_time %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-base-200/30 rounded-xl p-3 border border-base-200/50">
        <div class="text-[10px] font-bold uppercase tracking-widest opacity-40 mb-1">Infrastructure</div>
        <div class="flex items-center gap-2">
          <span class="text-lg font-bold"><%= room_count %></span>
          <span class="text-xs opacity-60">Rooms</span>
        </div>
      </div>
      <div class="bg-base-200/30 rounded-xl p-3 border border-base-200/50">
        <div class="text-[10px] font-bold uppercase tracking-widest opacity-40 mb-1">Devices</div>
        <div class="flex items-center gap-2">
          <span class="text-lg font-bold"><%= accessory_count %></span>
          <span class="text-xs opacity-60">Total</span>
        </div>
      </div>
      <div class="bg-base-200/30 rounded-xl p-3 border border-base-200/50">
        <div class="text-[10px] font-bold uppercase tracking-widest opacity-40 mb-1">Monitoring</div>
        <div class="flex items-center gap-2">
          <span class="text-lg font-bold text-success"><%= sensor_count %></span>
          <span class="text-xs opacity-60">Sensors</span>
        </div>
      </div>
      <div class="bg-base-200/30 rounded-xl p-3 border border-base-200/50">
        <div class="text-[10px] font-bold uppercase tracking-widest opacity-40 mb-1">Health</div>
        <div class="flex items-center gap-2 text-success">
          <span class="text-lg font-bold">100%</span>
          <span class="text-xs opacity-60">Online</span>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-2 pt-4 border-t border-base-200/50">
      <%= link_to home_path(home), class: "btn btn-primary btn-sm gap-2" do %>
        <span>Dashboard</span>
        <%= helpers.lucide_icon("chevron-right", size: 14) %>
      <% end %>
      <%= link_to home_rooms_path(home), class: "btn btn-ghost btn-sm gap-2 bg-base-200/50" do %>
        <%= helpers.lucide_icon("layout-grid", size: 14) %>
        <span>Rooms</span>
      <% end %>
      <%= link_to "#", class: "btn btn-ghost btn-sm btn-square bg-base-200/50" do %>
        <%= helpers.lucide_icon("history", size: 14) %>
      <% end %>
    </div>
  </div>
</div>
