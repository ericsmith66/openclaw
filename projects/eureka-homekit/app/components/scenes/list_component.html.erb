<% if empty? %>
  <div class="text-center py-12">
    <div class="text-6xl mb-4">⚡</div>
    <h2 class="text-2xl font-semibold text-gray-700 mb-2">No scenes configured</h2>
    <p class="text-gray-500">Use the Apple Home app to create scenes.</p>
  </div>
<% elsif should_group? %>
  <% grouped_scenes.each do |home_name, scenes| %>
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= home_name %></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <% scenes.each do |scene| %>
          <%= render Scenes::CardComponent.new(scene: scene, show_home: false) %>
        <% end %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <% @scenes.each do |scene| %>
      <%= render Scenes::CardComponent.new(scene: scene, show_home: show_home?) %>
    <% end %>
  </div>
<% end %>
