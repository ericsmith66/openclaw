<aside class="bg-base-100 border-l border-base-200 w-96 min-h-screen flex flex-col" 
       data-controller="sidebar recent-events"
       data-recent-events-context-type-value="<%= @context_type %>"
       data-recent-events-context-id-value="<%= @context_id %>">
  <div class="p-6 flex-none">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold tracking-tight"><%= @title %></h3>
      <button data-action="click->sidebar#scrollToTable" class="text-xs font-semibold text-primary hover:underline uppercase tracking-wider">
        Show in Table
      </button>
    </div>
    
    <div class="space-y-3" id="recent-events-list" data-recent-events-target="list">
      <% if @grouped_events.any? %>
        <% @grouped_events.each do |event, count| %>
          <%= render Events::RecentEventsItemComponent.new(event: event, count: count) %>
        <% end %>
      <% else %>
        <div class="flex flex-col items-center justify-center py-12 px-6 text-center bg-base-200/30 rounded-2xl border-2 border-dashed border-base-200">
          <div class="bg-base-100 p-3 rounded-full mb-4 shadow-sm">
            <%= helpers.lucide_icon("bell-off", size: 24, class: "opacity-20") %>
          </div>
          <p class="text-sm font-medium opacity-60">No recent events</p>
          <p class="text-[11px] opacity-40 mt-2 leading-relaxed">
            Ensure your Prefab/HomeKit bridge is running and connected. 
            Check bridge status in Settings.
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="p-6 mt-auto border-t border-base-200 bg-base-200/20">
    <div class="flex items-center justify-between mb-4">
      <h4 class="text-xs font-bold uppercase tracking-widest opacity-40">System Health</h4>
      <span class="badge badge-success badge-xs"></span>
    </div>
    <div class="space-y-3">
      <div class="flex items-center justify-between text-xs">
        <span class="opacity-60">CPU Usage</span>
        <span class="font-mono font-bold">12%</span>
      </div>
      <div class="w-full bg-base-200 rounded-full h-1">
        <div class="bg-success h-1 rounded-full" style="width: 12%"></div>
      </div>
      <div class="flex items-center justify-between text-xs">
        <span class="opacity-60">Memory</span>
        <span class="font-mono font-bold">452MB</span>
      </div>
      <div class="w-full bg-base-200 rounded-full h-1">
        <div class="bg-primary h-1 rounded-full" style="width: 35%"></div>
      </div>
    </div>
  </div>
</aside>
