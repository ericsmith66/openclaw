<aside class="bg-base-100 border-r border-base-200 w-80 min-h-screen flex flex-col">
  <div class="p-4 flex-none">
    <%= render Shared::SearchBarComponent.new(placeholder: "Search components...") %>
  </div>

  <div class="flex-1 overflow-y-auto p-4 pt-0">
    <ul class="menu menu-md w-full p-0 gap-1">
      <li class="menu-title opacity-40 text-xs font-bold uppercase tracking-wider">Navigation</li>
      <% menu_items.each do |item| %>
        <li>
          <%= link_to item[:path], class: "flex items-center gap-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors" do %>
            <%= helpers.lucide_icon(item[:icon], size: 18, class: "opacity-70") %>
            <span class="font-medium"><%= item[:label] %></span>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="mt-8">
      <ul class="menu menu-md w-full p-0 gap-1">
        <li class="menu-title opacity-40 text-xs font-bold uppercase tracking-wider">Your Homes</li>
        <% if @homes.any? %>
          <% @homes.each do |home| %>
            <li>
              <details open>
                <summary class="flex items-center gap-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors">
                  <%= helpers.lucide_icon("home", size: 18, class: "opacity-70") %>
                  <span class="font-medium"><%= home.name %></span>
                </summary>
                <ul>
                  <% home.rooms.sort_by { |r| r.name.downcase }.each do |room| %>
                    <li>
                      <%= link_to room_path(room), 
                          class: "py-2 px-4 rounded-lg hover:bg-base-200 transition-colors #{helpers.room_activity_color(room)}",
                          data: { 
                            controller: "room-activity",
                            room_activity_room_id_value: room.id,
                            room_activity_last_event_at_value: room.last_event_at&.iso8601
                          } do %>
                        <div class="flex items-center justify-between w-full">
                          <span class="room-name <%= helpers.room_activity_text_color(room) %>"><%= room.name %></span>
                          <% if room.sensors.present? %>
                            <span class="sensor-badge badge badge-ghost badge-sm opacity-50 <%= helpers.room_activity_text_color(room) %>"><%= room.sensors.size %></span>
                          <% end %>
                        </div>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </details>
            </li>
          <% end %>
        <% else %>
          <div class="p-4 text-sm opacity-50 italic">No homes found.</div>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="p-4 border-t border-base-200 bg-base-200/30">
    <div class="flex items-center gap-3">
      <div class="badge badge-success badge-xs"></div>
      <span class="text-xs font-medium opacity-70 italic">Local Controller Connected</span>
    </div>
  </div>
</aside>
