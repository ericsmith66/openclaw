<div data-controller="color-picker"
     data-color-picker-hue-value="<%= @hue %>"
     data-color-picker-saturation-value="<%= @saturation %>"
     class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
     data-action="click->color-picker#close_if_background">

  <div class="bg-white rounded-lg p-6 w-96 shadow-xl">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold">Light Color</h3>
      <button data-action="color-picker#close" class="text-gray-500 hover:text-gray-700">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <!-- Color preview swatch -->
    <div class="mb-4 h-16 rounded-lg flex items-center justify-center"
         data-color-picker-target="previewSwatch"
         style="background-color: hsl(<%= @hue %>, <%= @saturation %>%, 50%);">
    </div>
    <!-- Hue slider -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Hue</label>
      <input type="range"
             min="0" max="360"
             value="<%= @hue %>"
             data-color-picker-target="hueSlider"
             data-action="input->color-picker#update_preview"
             <% if offline? %>disabled<% end %>
             class="range range-sm range-primary w-full h-2">
      <div class="flex justify-between text-xs text-gray-500 mt-1">
        <span>0°</span>
        <span data-color-picker-target="hueValue"><%= @hue %></span>
        <span>360°</span>
      </div>
    </div>
    <!-- Saturation slider -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Saturation</label>
      <input type="range"
             min="0" max="100"
             value="<%= @saturation %>"
             data-color-picker-target="saturationSlider"
             data-action="input->color-picker#update_preview"
             <% if offline? %>disabled<% end %>
             class="range range-sm range-secondary w-full h-2">
      <div class="flex justify-between text-xs text-gray-500 mt-1">
        <span>0%</span>
        <span data-color-picker-target="saturationValue"><%= @saturation %>%</span>
        <span>100%</span>
      </div>
    </div>
    <!-- Action buttons -->
    <div class="flex justify-end space-x-2">
      <button data-action="color-picker#close"
              class="btn btn-sm btn-ghost">Cancel</button>
      <button data-action="color-picker#apply"
              <% if offline? %>disabled<% end %>
              class="btn btn-sm btn-primary">Apply</button>
    </div>
  </div>
</div>
