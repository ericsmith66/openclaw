<div data-controller="favorites">
  <% if empty? %>
    <div class="text-center py-12" data-favorites-target="emptyState">
      <div class="text-6xl mb-4">⭐</div>
      <h2 class="text-2xl font-semibold text-gray-700 mb-2">No favorites yet</h2>
      <p class="text-gray-500 mb-4">Star accessories from any room page for quick access.</p>
      <%= link_to 'Browse Rooms', rooms_path, class: 'btn btn-primary btn-sm' %>
    </div>
  <% else %>
    <!-- Favorites grid -->
    <div data-favorites-target="grid"
         class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% favorite_accessories.each do |accessory| %>
        <div data-favorite-uuid="<%= accessory.uuid %>"
             class="bg-base-100 rounded-2xl border border-base-200 shadow-sm p-4 cursor-grab active:cursor-grabbing transition-all hover:shadow-md">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <button class="text-lg cursor-pointer hover:scale-110 transition-transform text-yellow-500"
                      data-favorites-target="star"
                      data-accessory-uuid="<%= accessory.uuid %>"
                      data-accessory-name="<%= accessory.name %>"
                      data-action="click->favorites#toggleFavorite"
                      aria-label="Remove <%= accessory.name %> from favorites">
                ★
              </button>
              <div>
                <h3 class="font-bold text-sm"><%= accessory.name %></h3>
                <p class="text-xs opacity-50"><%= accessory.room&.name %> · <%= accessory.room&.home&.name %></p>
              </div>
            </div>
          </div>
          <%= render Controls::AccessoryControlComponent.new(accessory: accessory, compact: true, show_favorite: false) %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- All accessories (hidden, for star toggling on other views) -->
  <% all_accessories.each do |accessory| %>
    <% unless favorited?(accessory) %>
      <div data-favorite-uuid="<%= accessory.uuid %>" class="hidden">
        <div class="bg-base-100 rounded-2xl border border-base-200 shadow-sm p-4">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <button class="text-lg cursor-pointer hover:scale-110 transition-transform text-base-content/30"
                      data-favorites-target="star"
                      data-accessory-uuid="<%= accessory.uuid %>"
                      data-accessory-name="<%= accessory.name %>"
                      data-action="click->favorites#toggleFavorite"
                      aria-label="Add <%= accessory.name %> to favorites">
                ☆
              </button>
              <div>
                <h3 class="font-bold text-sm"><%= accessory.name %></h3>
                <p class="text-xs opacity-50"><%= accessory.room&.name %> · <%= accessory.room&.home&.name %></p>
              </div>
            </div>
          </div>
          <%= render Controls::AccessoryControlComponent.new(accessory: accessory, compact: true, show_favorite: false) %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
