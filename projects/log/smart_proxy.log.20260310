:{"type":"integer","default":50,"minimum":1}},"required":["file_pattern","search_term"],"additionalProperties":false}}},{"type":"function","function":{"name":"power---bash","description":"Executes a shell command. For safety, commands may be sandboxed or require user approval (approval handled by Agent).","parameters":{"type":"object","properties":{"command":{"type":"string"},"cwd":{"type":"string","default":""},"timeout":{"type":"integer","default":120000,"minimum":0}},"required":["command"],"additionalProperties":false}}},{"type":"function","function":{"name":"power---fetch","description":"Fetches and returns the content of a web page from a specified URL. Useful for retrieving web content, documentation, or external resources. Supports three formats: \"markdown\" (default, converts HTML to markdown), \"html\" (returns raw HTML), \"raw\" (fetches raw content via HTTP, ideal for API responses or raw files like GitHub raw files).","parameters":{"type":"object","properties":{"url":{"type":"string"},"timeout":{"type":"integer","default":60000,"minimum":0},"format":{"type":"string","enum":["markdown","html","raw"],"default":"markdown"}},"required":["url"],"additionalProperties":false}}}]}}}
