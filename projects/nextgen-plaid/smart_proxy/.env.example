# SmartProxy Environment Variables
# Copy this file to .env and fill in the values

# The API Key for xAI (Grok)
GROK_API_KEY=your_grok_api_key_here

# The API Key for Anthropic (Claude)
CLAUDE_API_KEY=your_claude_api_key_here

# The token required by the Rails app to authenticate with this proxy
PROXY_AUTH_TOKEN=your_secure_proxy_token_here

# Optional: List of Claude models to expose (comma-separated)
# CLAUDE_MODELS=claude-3-5-sonnet-latest,claude-3-opus-latest

# Optional: Port for the Sinatra server (default: 4567)
SMART_PROXY_PORT=4567
