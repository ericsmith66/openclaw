<div class="drawer lg:drawer-open" data-theme="business">
  <input id="main-drawer" type="checkbox" class="drawer-toggle" />
  
  <div class="drawer-content flex flex-col">
    <!-- Top Navbar -->
    <%= render NavigationComponent.new(current_user: @current_user) %>
    
    <!-- Main Content -->
    <main class="flex-1 p-6 bg-base-200">
      <% if @title.present? %>
        <div class="flex items-center justify-between mb-4">
          <div class="text-sm breadcrumbs">
            <ul>
              <li><a href="/">Home</a></li>
              <% if @breadcrumb_segments.present? %>
                <% @breadcrumb_segments.each do |label, path| %>
                  <% if path.present? %>
                    <li><a href="<%= path %>"><%= label %></a></li>
                  <% else %>
                    <li><%= label %></li>
                  <% end %>
                <% end %>
              <% else %>
                <li><%= @title %></li>
              <% end %>
            </ul>
          </div>
          <% if show_account_filter? %>
            <form action="<%= @account_filter_path %>" method="get" class="flex-shrink-0">
              <select name="account" class="select select-bordered select-sm w-48" aria-label="Filter by account" onchange="this.form.submit()">
                <% account_options.each do |label, value| %>
                  <option value="<%= value %>" <%= 'selected' if value == @selected_account %>><%= label %></option>
                <% end %>
              </select>
            </form>
          <% end %>
        </div>
      <% end %>
      
      <%= content %>
    </main>
  </div>
  
  <!-- Left Sidebar -->
  <div class="drawer-side">
    <label for="main-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <aside class="bg-base-100 min-h-full w-64 p-4">
      <div class="mb-4">
        <h2 class="text-lg font-bold text-base-content px-4">Menu</h2>
      </div>
      <ul class="menu bg-base-100 rounded-box">
