<div class="p-4 sm:p-6 overflow-x-hidden">
  <div class="breadcrumbs text-sm mb-3" aria-label="Breadcrumb">
    <ul>
      <li><%= link_to "Home", authenticated_root_path, class: "link link-hover" %></li>
      <li>Portfolio</li>
      <li><%= link_to "Holdings", back_to_holdings_url, class: "link link-hover" %></li>
      <li><%= ticker %></li>
    </ul>
  </div>

  <div class="flex items-center justify-between gap-4 flex-wrap">
    <div>
      <div class="flex items-center gap-3">
        <% if logo_url.present? %>
          <img src="<%= logo_url %>" alt="<%= ticker %> logo" class="w-10 h-10 rounded bg-base-200" loading="lazy" />
        <% end %>
        <div>
          <div class="text-2xl font-bold"><%= ticker %></div>
          <div class="opacity-80"><%= company_name %></div>
        </div>
      </div>

      <div class="mt-2 flex items-center gap-3 flex-wrap">
        <div class="text-sm">
          <span class="opacity-70">Current Price:</span>
          <span class="font-medium"><%= current_price.present? ? number_to_currency(current_price, precision: 2) : "N/A" %></span>
        </div>
        <div class="text-sm">
          <span class="opacity-70">Enrichment Updated:</span>
          <span class="<%= enrichment_badge_class %>"><%= enrichment_label %></span>
        </div>
      </div>
    </div>

    <div>
      <%= link_to "\u2190 Back to Holdings", back_to_holdings_url, class: "btn btn-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mt-5">
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div class="card-title text-base">Core Data</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          <div><span class="opacity-70">Type:</span> <span class="font-medium"><%= na(holdings.first&.type) %></span></div>
          <div><span class="opacity-70">Sector:</span> <span class="font-medium"><%= na(enrichment&.sector || holdings.first&.sector) %></span></div>
          <div><span class="opacity-70">Industry:</span> <span class="font-medium"><%= na(enrichment&.industry || holdings.first&.industry) %></span></div>
          <div><span class="opacity-70">CUSIP:</span> <span class="font-medium"><%= na(holdings.first&.cusip) %></span></div>
          <div><span class="opacity-70">ISIN:</span> <span class="font-medium"><%= na(holdings.first&.isin) %></span></div>
        </div>
        <div class="mt-3 text-sm">
          <div class="opacity-70 mb-1">Description</div>
          <div class="prose prose-sm max-w-none">
            <%= na(enrichment&.description) %>
          </div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div class="card-title text-base">Market &amp; Valuation</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          <div><span class="opacity-70">Price:</span> <span class="font-medium"><%= enrichment&.price.present? ? number_to_currency(enrichment.price, precision: 2) : "N/A" %></span></div>
          <div><span class="opacity-70">Market Cap:</span> <span class="font-medium"><%= enrichment&.market_cap.present? ? number_to_currency(enrichment.market_cap, precision: 0) : "N/A" %></span></div>
          <div><span class="opacity-70">Change %:</span> <span class="font-medium"><%= enrichment&.change_percentage.present? ? number_to_percentage(enrichment.change_percentage, precision: 2) : "N/A" %></span></div>
        </div>
        <div class="text-xs opacity-70 mt-2">52-week high/low and volume not yet available in enrichment schema.</div>
      </div>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div class="card-title text-base">Fundamentals</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          <div><span class="opacity-70">P/E:</span> <span class="font-medium"><%= enrichment&.pe_ratio.present? ? number_with_precision(enrichment.pe_ratio, precision: 2) : "N/A" %></span></div>
          <div><span class="opacity-70">Beta:</span> <span class="font-medium"><%= enrichment&.beta.present? ? number_with_precision(enrichment.beta, precision: 2) : "N/A" %></span></div>
          <div><span class="opacity-70">Dividend Yield:</span> <span class="font-medium"><%= enrichment&.dividend_yield.present? ? number_to_percentage(enrichment.dividend_yield * 100.0, precision: 2) : "N/A" %></span></div>
          <div><span class="opacity-70">Dividend/Share:</span> <span class="font-medium"><%= enrichment&.dividend_per_share.present? ? number_to_currency(enrichment.dividend_per_share, precision: 2) : "N/A" %></span></div>
        </div>
        <div class="text-xs opacity-70 mt-2">EPS not yet available in enrichment schema.</div>
      </div>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div class="card-title text-base">Holdings Summary</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          <div><span class="opacity-70">Total quantity:</span> <span class="font-medium"><%= number_with_precision(holdings_summary[:total_quantity], precision: 4, strip_insignificant_zeros: true) %></span></div>
          <div><span class="opacity-70">Total market value:</span> <span class="font-medium"><%= number_to_currency(holdings_summary[:total_market_value], precision: 0) %></span></div>
          <div><span class="opacity-70">Average cost (sum, phase 1):</span> <span class="font-medium"><%= number_to_currency(holdings_summary[:total_cost_basis], precision: 0) %></span></div>
          <div>
            <span class="opacity-70">Total unrealized G/L:</span>
            <span class="font-medium"><%= number_to_currency(holdings_summary[:total_unrealized_gl], precision: 0) %></span>
            <span class="opacity-80">(<%= number_to_percentage(holdings_summary[:total_unrealized_gl_pct], precision: 1) %>)</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow mt-4">
    <div class="card-body">
      <div class="card-title text-base">Per-Account Breakdown</div>

      <% if holdings_by_account.empty? %>
        <div class="text-sm opacity-80">No current holdings found for this security.</div>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-zebra table-sm w-full" aria-label="Per-account holdings">
            <thead>
              <tr>
                <th>Account</th>
                <th class="text-right">Quantity</th>
                <th class="text-right">Value</th>
                <th class="text-right">Cost Basis</th>
                <th class="text-right">Unrealized G/L ($)</th>
                <th class="text-right">Unrealized G/L (%)</th>
              </tr>
            </thead>
            <tbody>
              <% holdings_by_account.each do |row| %>
                <% account = row[:account] %>
                <tr>
                  <td><%= [account.name, account.mask.presence && "• #{account.mask}"].compact.join(" ") %></td>
                  <td class="text-right"><%= number_with_precision(row[:quantity], precision: 4, strip_insignificant_zeros: true) %></td>
                  <td class="text-right"><%= number_to_currency(row[:market_value], precision: 0) %></td>
                  <td class="text-right"><%= number_to_currency(row[:cost_basis], precision: 0) %></td>
                  <td class="text-right"><%= number_to_currency(row[:unrealized_gl], precision: 0) %></td>
                  <td class="text-right"><%= number_to_percentage(row[:unrealized_gl_pct], precision: 1) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card bg-base-100 shadow mt-4">
    <div class="card-body">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div class="card-title text-base">Transactions</div>

        <div class="flex items-center gap-2">
          <span class="text-sm opacity-70">Rows:</span>
          <% PER_PAGE_OPTIONS.each do |opt| %>
            <% active = per_page.to_s == opt.to_s %>
            <%= link_to opt.to_s.upcase,
                  per_page_link(opt),
                  class: "btn btn-xs #{active ? 'btn-primary' : 'btn-ghost'}" %>
          <% end %>
        </div>
      </div>

      <% if transactions.empty? %>
        <div class="text-sm opacity-80 mt-2">No transactions found for this security.</div>
      <% else %>
        <div class="overflow-x-auto mt-2">
          <table class="table table-zebra table-sm w-full" aria-label="Security transactions">
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Description</th>
                <th class="text-right">Amount</th>
                <th class="text-right">Quantity</th>
                <th class="text-right">Price</th>
                <th class="text-right">Fees</th>
                <th>Source</th>
                <th>Account</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.each do |tx| %>
                <tr>
                  <td><%= tx.date %></td>
                  <td><%= (tx.transaction_type.presence || tx.subtype.presence || tx.type).to_s %></td>
                  <td><%= tx.name.to_s %></td>
                  <td class="text-right <%= tx_amount_class(tx.amount) %>"><%= number_to_currency(tx.amount.to_f, precision: 2) %></td>
                  <td class="text-right"><%= tx.quantity.present? ? number_with_precision(tx.quantity.to_f, precision: 4, strip_insignificant_zeros: true) : "—" %></td>
                  <td class="text-right"><%= tx.price.present? ? number_to_currency(tx.price.to_f, precision: 4) : "—" %></td>
                  <td class="text-right"><%= tx.fees.present? ? number_to_currency(tx.fees.to_f, precision: 2) : "—" %></td>
                  <td><%= tx.source.to_s %></td>
                  <td><%= [tx.account&.name, tx.account&.mask.presence && "• #{tx.account.mask}"].compact.join(" ") %></td>
                </tr>
              <% end %>

              <tr class="bg-base-200 font-medium">
                <td colspan="9" class="text-right">
                  Invested: <%= number_to_currency(transaction_totals[:invested], precision: 2) %>
                  &nbsp;•&nbsp; Proceeds: <%= number_to_currency(transaction_totals[:proceeds], precision: 2) %>
                  &nbsp;•&nbsp; Net Cash Flow: <%= number_to_currency(transaction_totals[:net_cash_flow], precision: 2) %>
                  &nbsp;•&nbsp; Dividends: <%= number_to_currency(transaction_totals[:dividends], precision: 2) %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <% if per_page.to_s != "all" && total_pages > 1 %>
          <div class="join mt-3">
            <%= link_to "Prev",
                  page_link([page - 1, 1].max),
                  class: "btn btn-sm join-item #{page <= 1 ? 'btn-disabled' : ''}" %>
            <div class="btn btn-sm join-item btn-ghost" aria-label="Page indicator">
              Page <%= page %> of <%= total_pages %>
            </div>
            <%= link_to "Next",
                  page_link([page + 1, total_pages].min),
                  class: "btn btn-sm join-item #{page >= total_pages ? 'btn-disabled' : ''}" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
