<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <div class="flex items-center justify-between gap-3">
      <h2 class="card-title">Performance</h2>
      <div class="text-xs opacity-70">30 days</div>
    </div>

    <% if missing_data? %>
      <%= render NetWorth::EmptyStateComponent.new(context: :data_missing) %>
    <% elsif corrupt? %>
      <div class="text-sm opacity-70 mt-3">Data temporarily unavailable.</div>
    <% elsif insufficient_history? %>
      <div class="text-sm opacity-70 mt-3">Insufficient history for trend. Check back after a few days.</div>
    <% else %>
      <% unless chart_error? %>
        <div class="mt-4 min-w-0">
          <% begin %>
            <%= line_chart(
                  [{ name: "Net Worth", data: chart_points }],
                  **line_chart_options
                ) %>
          <% rescue StandardError => e %>
            <% mark_chart_error!(e) %>
          <% end %>
        </div>
      <% end %>

      <table class="sr-only" aria-label="Net worth performance history (accessible fallback)">
        <thead>
          <tr>
            <th>Date</th>
            <th>Total</th>
            <th>Day-over-day delta</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |row| %>
            <tr>
              <td><%= row[:date] %></td>
              <td><%= number_to_currency(row[:total].to_f, precision: 0) %></td>
              <td>
                <% if row[:delta].nil? %>
                  —
                <% else %>
                  <%= number_to_currency(row[:delta].to_f, precision: 0) %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
