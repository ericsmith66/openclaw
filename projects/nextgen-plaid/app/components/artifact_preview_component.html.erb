<div id="artifact-preview-container" 
     class="w-96 border-l border-base-300 bg-base-50 flex flex-col h-full" 
     data-controller="artifact-preview"
     data-artifact-preview-artifact-id-value="<%= @artifact.id %>">
  <%= turbo_stream_from "artifact_#{@artifact.id}" %>
  <% if user_id %>
    <%= turbo_stream_from "active_artifacts_user_#{user_id}" %>
  <% end %>
  <div class="p-4 border-b border-base-300 bg-white">
    <div class="flex justify-between items-start mb-2">
      <h2 class="font-bold text-lg truncate" title="<%= name %>"><%= name %></h2>
      <span class="badge badge-sm badge-outline"><%= owner %></span>
    </div>
    
    <div class="flex items-center gap-2 mb-4">
      <div class="badge badge-info gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <%= phase.humanize %>
      </div>
      <span class="text-xs text-gray-400">Updated: <%= updated_at %></span>
    </div>

    <div class="tabs tabs-boxed">
      <button class="tab tab-sm flex-grow" 
              data-artifact-preview-target="tab" 
              data-action="click->artifact-preview#switchView" 
              data-view="prd">PRD</button>
      <button class="tab tab-sm flex-grow" 
              data-artifact-preview-target="tab" 
              data-action="click->artifact-preview#switchView" 
              data-view="plan">Plan</button>
    </div>
  </div>

  <div class="flex-grow overflow-y-auto p-4">
    <div data-artifact-preview-target="prdView" class="prose prose-sm max-w-none">
      <%= markdown(prd_content) %>
    </div>

    <div data-artifact-preview-target="planView" class="hidden">
      <h3 class="font-bold mb-2">Technical Plan</h3>
      <% if tasks.any? %>
        <ul class="space-y-2 mb-4">
          <% tasks.each do |task| %>
            <li class="p-2 border border-base-200 rounded-md bg-white">
              <div class="flex items-start gap-2">
                <input type="checkbox" <%= 'checked' if task['status'] == 'completed' || task['completed'] == true %> disabled class="checkbox checkbox-xs mt-1" />
                <div>
                  <div class="text-sm font-medium"><%= task['title'] %></div>
                  <div class="text-xs text-gray-500"><%= task['id'] %> • <%= task['estimate'] %></div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm italic text-gray-500 mb-4">No tasks defined yet.</p>
      <% end %>

      <% if implementation_notes.present? %>
        <div class="mt-4 p-3 bg-blue-50 border border-blue-100 rounded-md">
          <h4 class="text-xs font-bold text-blue-700 uppercase mb-1">Implementation Notes</h4>
          <div class="text-sm text-blue-900 prose prose-sm prose-blue max-w-none"><%= markdown(implementation_notes) %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Simple listener for direct DOM updates if needed, though Turbo is preferred
  document.addEventListener("artifact:updated", (event) => {
    // We could trigger a turbo reload here if we wanted
  });
</script>
