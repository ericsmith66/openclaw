<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h2 class="card-title">Asset Allocation</h2>

    <% if rows.empty? %>
      <div class="text-sm opacity-70">No allocation data available.</div>
    <% else %>
      <div class="space-y-2 mt-2">
        <% rows.each do |key, pct| %>
          <div>
            <div class="flex items-center justify-between text-sm">
              <div class="font-medium"><%= key.tr('_', ' ').titleize %></div>
              <div><%= (pct * 100).round %>%</div>
            </div>
            <progress class="progress progress-primary w-full" value="<%= (pct * 100).round(2) %>" max="100"></progress>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
