<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <div class="flex items-start justify-between">
      <div>
        <h2 class="card-title">Total Net Worth</h2>
        <div class="text-3xl font-bold mt-2"><%= number_to_currency(@data["total_net_worth"].to_f, precision: 0) %></div>
      </div>
      <div class="text-right text-sm opacity-70">
        <div>1D: <span class="font-semibold"><%= number_to_currency(@data["delta_day"].to_f, precision: 0) %></span></div>
        <div>30D: <span class="font-semibold"><%= number_to_currency(@data["delta_30d"].to_f, precision: 0) %></span></div>
      </div>
    </div>

    <% disclaimer = @data["disclaimer"].to_s %>
    <% if disclaimer.present? %>
      <div class="text-xs opacity-60 mt-4"><%= disclaimer %></div>
    <% end %>
  </div>
</div>
