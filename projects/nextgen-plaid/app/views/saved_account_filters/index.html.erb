<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between gap-4 mb-6">
    <h1 class="text-xl font-semibold">Saved Account Filters</h1>
    <%= link_to "New Filter", new_saved_account_filter_path, class: "btn btn-sm btn-primary" %>
  </div>

  <% if @saved_account_filters.blank? %>
    <div class="alert">
      <span>No saved filters yet.</span>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Context</th>
            <th>Criteria</th>
            <th class="w-40"></th>
          </tr>
        </thead>
        <tbody>
          <% @saved_account_filters.each do |filter| %>
            <tr>
              <td class="font-medium"><%= filter.name %></td>
              <td><%= filter.context.presence || "—" %></td>
              <td class="text-xs text-base-content/70">
                <code><%= filter.criteria.to_json %></code>
              </td>
              <td class="text-right">
                <div class="flex justify-end gap-2">
                  <%= link_to "Edit", edit_saved_account_filter_path(filter), class: "btn btn-xs btn-outline" %>
                  <%= button_to "Delete", saved_account_filter_path(filter), method: :delete, class: "btn btn-xs btn-error btn-outline", data: { turbo_confirm: "Delete this saved filter?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
