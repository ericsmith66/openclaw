<div class="p-6">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold">Snapshot</h1>
      <div class="text-sm opacity-70">
        <span><%= @snapshot.user&.email %></span>
        <span class="mx-2">•</span>
        <span><%= @snapshot.snapshot_at&.to_date %></span>
        <span class="mx-2">•</span>
        <span class="badge badge-outline"><%= @snapshot.status %></span>
      </div>
    </div>

    <div>
      <%= link_to "Back", admin_snapshots_path, class: "btn btn-ghost" %>
    </div>
  </div>

  <% if @snapshot.warnings.any? %>
    <div class="alert alert-warning mb-4">
      <div>
        <div class="font-semibold">Warnings</div>
        <ul class="list-disc ml-6">
          <% @snapshot.warnings.each do |w| %>
            <li><%= w %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <pre class="prose max-w-none bg-base-200 p-4 rounded"><%= @pretty_json %></pre>
</div>
