<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Ownership Lookups", admin_ownership_lookups_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-md">
    <div class="border-b pb-4 mb-4">
      <h2 class="text-2xl font-bold text-gray-900">Ownership Lookup Details</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-500">Name</label>
        <p class="text-gray-900"><%= @ownership_lookup.name %></p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-500">Ownership Type</label>
        <p class="text-gray-900"><%= @ownership_lookup.ownership_type %></p>
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-500">Details</label>
        <p class="text-gray-900 whitespace-pre-line"><%= @ownership_lookup.details.presence || "N/A" %></p>
      </div>
    </div>

    <div class="mt-6 pt-4 border-t">
      <label class="block text-sm font-medium text-gray-500 mb-2">Accounts</label>
      <p class="text-lg font-semibold text-gray-900"><%= @ownership_lookup.accounts.count %></p>
    </div>
  </div>

  <div class="mt-6 flex gap-3">
    <%= link_to "Edit", edit_admin_ownership_lookup_path(@ownership_lookup), class: "bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 px-4 rounded" %>
    <%= button_to "Delete", admin_ownership_lookup_path(@ownership_lookup), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded" %>
  </div>
</div>
