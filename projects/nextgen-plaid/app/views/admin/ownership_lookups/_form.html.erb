<%= form_with(model: [:admin, ownership_lookup], local: true, class: "space-y-4") do |form| %>
  <% if ownership_lookup.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded">
      <p class="font-semibold mb-2">Please fix the following errors:</p>
      <ul class="list-disc pl-6">
        <% ownership_lookup.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded border-gray-300" %>
  </div>

  <div>
    <%= form.label :ownership_type, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :ownership_type,
                    OwnershipLookup::OWNERSHIP_TYPES,
                    {},
                    class: "mt-1 block w-full rounded border-gray-300" %>
  </div>

  <div>
    <%= form.label :details, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :details, rows: 4, class: "mt-1 block w-full rounded border-gray-300" %>
  </div>

  <div class="flex gap-3">
    <%= form.submit class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded" %>
    <%= link_to "Cancel", admin_ownership_lookups_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded" %>
  </div>
<% end %>
