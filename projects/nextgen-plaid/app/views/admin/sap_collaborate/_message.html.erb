<% if message.system_role? %>
  <div id="<%= dom_id(message) %>" class="flex justify-center my-4 w-full">
    <div class="bg-base-200 text-base-content/60 text-xs py-1 px-4 rounded-full border border-base-300 italic">
      <%= message.content %>
    </div>
  </div>
<% else %>
  <% alignment_class = message.user_role? ? "justify-end" : "justify-start" %>
  <% bubble_class = message.user_role? ? "bg-primary text-primary-content" : "bg-base-300 text-base-content" %>

  <div id="<%= dom_id(message) %>" class="flex <%= alignment_class %>">
    <div class="max-w-[80ch] rounded-lg px-3 py-2 <%= bubble_class %>">
      <div class="text-xs opacity-60 mb-1">
        <%= message.role %>
        ·
        <%= message.created_at.strftime("%H:%M:%S") %>
      </div>
      <div class="prose prose-sm max-w-none">
        <%= simple_format(message.content) %>
      </div>
    </div>
  </div>
<% end %>
