<%= render(LayoutComponent.new(title: "Your Other Income Sources", current_user: current_user)) do %>
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold">Your Other Income Sources</h1>
      <div class="mt-2 text-sm">
        <span class="font-medium">Estimated annual total:</span>
        <span><%= number_to_currency(@estimated_annual_total) %></span>
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        <%= link_to "Sort: Name", other_incomes_path(sort: nil), class: "btn btn-outline btn-sm" %>
        <%= link_to "Sort: Amount", other_incomes_path(sort: "amount_desc"), class: "btn btn-outline btn-sm" %>
        <%= link_to "Sort: Updated", other_incomes_path(sort: "updated_at_desc"), class: "btn btn-outline btn-sm" %>
      </div>
    </div>

    <div class="shrink-0">
      <%= link_to "New Other Income Source", new_other_income_path, class: "btn btn-primary" %>
    </div>
  </div>

  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th>Name</th>
        <th class="text-right">Amount</th>
        <th>Frequency</th>
        <th>Category</th>
        <th>Taxable</th>
        <th>Start</th>
        <th>End</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @other_incomes.each do |oi| %>
        <tr>
          <td><%= oi.name %></td>
          <td class="text-right"><%= number_to_currency(oi.amount) %></td>
          <td><%= oi.frequency %></td>
          <td><%= oi.category.presence || "—" %></td>
          <td><%= oi.taxable? ? "Yes" : "No" %></td>
          <td><%= oi.start_date.presence || "—" %></td>
          <td><%= oi.end_date.presence || "—" %></td>
          <td class="text-right">
            <div class="flex justify-end gap-2">
              <%= link_to "Edit", edit_other_income_path(oi), class: "btn btn-outline btn-sm" %>
              <%= link_to "Delete",
                          other_income_path(oi),
                          class: "btn btn-outline btn-sm",
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?", confirm: "Are you sure?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
