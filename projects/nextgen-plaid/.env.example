# Local development environment variables (example)
# Copy to `.env` and fill values. Do NOT commit real secrets.

# Rails
RAILS_ENV=development

# Plaid (Sandbox)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=<PLAID_CLIENT_ID>
PLAID_SECRET=<PLAID_SECRET>
PLAID_REDIRECT_URI=http://localhost:3000/plaid_oauth/callback

# Encryption for `attr_encrypted` (32 bytes hex)
ENCRYPTION_KEY=<64_CHAR_HEX>

# Admin / owner controls
OWNER_EMAIL=ericsmith66@me.com

# Epic-2 / RAG exports
# Random salt used to hash `user_id` in RAG export context.
RAG_SALT=<RANDOM_SALT>

# Optional: allow machine access to `/api/snapshots/:id/rag_context`.
# If unset, the endpoint requires an authenticated admin user.
RAG_EXPORT_API_KEY=<RANDOM_API_KEY>
