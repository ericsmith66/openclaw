# frozen_string_literal: true

require "test_helper"

class RetryFlowIntegrationTest < ActionDispatch::IntegrationTest
  # Disable transactional tests so subprocess can see test data
  self.use_transactional_tests = false

  # Setup common test data
  setup do
    # Use a temporary project path for each test with unique identifier
    @project_path = Rails.root.join("tmp", "retry-test-project-#{Time.now.to_i}-#{SecureRandom.hex(4)}")
    @project = create(:project, path: @project_path.to_s)
    
    # Create agent team
    @team = create(:agent_team, project: @project, name: "ROR")
    
    # Create team membership (QA agent)
    @membership = create(:team_membership,
                        agent_team: @team,
                        config: {
                          "id" => "qa",
                          "name" => "QA Agent",
                          "provider" => "smart_proxy",
                          "model" => "deepseek-reasoner"
                        })
    @team.team_memberships << @membership
    @team.save!
    
    # Create a workflow execution
    @execution = create(:workflow_execution,
                       project: @project,
                       phase: :executing,
                       attempt: 1,
                       task_retry_limit: 3,
                       prd_path: "test_prd.md")
    
    # Create a workflow run associated with the execution
    @workflow_run = create(:workflow_run,
                          project: @project,
                          team_membership: @membership,
                          prompt: "Test workflow",
                          status: :completed,
                          result: "Workflow completed successfully")
    
    # Add workflow_run to execution
    @execution.workflow_runs << @workflow_run
    
    # Create tasks for the workflow run (with failed status so they can be reset)
    @task1 = create(:task,
                   project: @project,
                   team_membership: @membership,
                   workflow_run: @workflow_run,
                   workflow_execution: @execution,
                   position: 1,
                   prompt: "Build the application",
                   task_type: :code,
                   status: "failed",
                   result: "Build failed",
                   retry_count: 0)
    @task2 = create(:task,
                   project: @project,
                   team_membership: @membership,
                   workflow_run: @workflow_run,
                   workflow_execution: @execution,
                   position: 2,
                   prompt: "Write tests",
                   task_type: :code,
                   status: "failed",
                   result: "Tests failed",
                   retry_count: 0)
  end

  teardown do
    # Clean up test project directory
    FileUtils.rm_rf(@project.path) if File.directory?(@project.path)

    # Clean up database records since transactional tests are disabled
    Task.delete_all
    WorkflowRun.delete_all
    WorkflowExecution.delete_all
    TeamMembership.delete_all
    AgentTeam.delete_all
    Project.delete_all
  end

  # =============================================================================
  # AC-1: QA score below threshold triggers retry_with_context
  # =============================================================================

  test "AC-1: QA score below threshold triggers retry_with_context" do
    # Create a score report with score below threshold (90)
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssues in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # Debug: Check task status before retry
    Rails.logger.info("Task1 status before retry: #{@task1.reload.status}, retry_count: #{@task1.reload.retry_count}")
    Rails.logger.info("Task2 status before retry: #{@task2.reload.status}, retry_count: #{@task2.reload.retry_count}")

    # Execute retry_with_context
    result = Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Debug: Check task status after retry
    Rails.logger.info("Task1 status after retry: #{@task1.reload.status}, retry_count: #{@task1.reload.retry_count}")
    Rails.logger.info("Task2 status after retry: #{@task2.reload.status}, retry_count: #{@task2.reload.retry_count}")

    # Verify attempt was incremented
    assert_equal 2, @execution.reload.attempt, "Expected attempt to be incremented to 2"
    assert_equal "iterating", @execution.reload.phase, "Expected phase to be iterating"

    # Verify tasks were reset
    task1 = @task1.reload
    task2 = @task2.reload
    assert task1.status.in?(["pending", "ready"]), "Expected task1 to be reset, but was #{task1.status}"
    assert task2.status.in?(["pending", "ready"]), "Expected task2 to be reset, but was #{task2.status}"

    # Verify artifacts were created
    assert_equal 2, @execution.artifacts.where(artifact_type: [:retry_context, :review_feedback]).count,
                 "Expected retry_context and review_feedback artifacts to be created"
  end

  # =============================================================================
  # AC-2: Tasks reset with accumulated context
  # =============================================================================

  test "AC-2: Tasks reset with accumulated context on retry" do
    # Create first score report
    score_report1 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 1",
      content: "# Score\n85/100\n\n## Feedback\nFirst issue in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # First retry
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report1
    )

    # Create second score report (second attempt still below threshold)
    execution2 = @execution.reload
    score_report2 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution2,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 2",
      content: "# Score\n88/100\n\n## Feedback\nSecond issue in app/models/user.rb",
      metadata: { "score" => 88 }
    )

    # Second retry
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: execution2,
      score_report: score_report2
    )

    # Verify accumulated context
    execution3 = execution2.reload
    retry_context = execution3.artifacts.find_by(artifact_type: :retry_context)

    assert retry_context, "Expected retry_context artifact to exist"
    assert_includes retry_context.content, "attempt_1", "Expected attempt_1 context to be accumulated"
    assert_includes retry_context.content, "First issue", "Expected first feedback to be accumulated"
    assert_includes retry_context.content, "Second issue", "Expected second feedback to be accumulated"
  end

  # =============================================================================
  # AC-3: Re-dispatch uses enriched prompts
  # =============================================================================

  test "AC-3: Re-dispatch uses enriched prompts with prior feedback" do
    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssue in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Reload tasks to get updated prompts
    task1 = @task1.reload
    task2 = @task2.reload

    # Verify prompts include prior feedback
    # The error_context_enriched_prompt should include the previous attempt's error
    assert_includes task1.error_context_enriched_prompt, "Previous attempt failed", "Expected enriched prompt to include failure context"
    assert_includes task2.error_context_enriched_prompt, "Previous attempt failed", "Expected enriched prompt to include failure context"
  end

  # =============================================================================
  # AC-4: Subsequent QA passes
  # =============================================================================

  test "AC-4: Subsequent QA passes after retry" do
    # Create score report with low score
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssue in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # First retry
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Create a passing score report for the retry
    execution2 = @execution.reload
    passing_score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution2,
      created_by: @team,
      artifact_type: :score_report,
      name: "Passing Score Report",
      content: "# Score\n95/100\n\n## Feedback\nAll issues resolved",
      metadata: { "score" => 95 }
    )

    # Verify that retry_with_context would not be triggered for passing score
    assert_raises(Legion::OrchestrationTools::RetryWithContext::PreconditionError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: execution2,
        score_report: passing_score_report
      )
    end
  end

  # =============================================================================
  # AC-5: Artifacts created and prompts include prior feedback
  # =============================================================================

  test "AC-5: Artifacts created with prior feedback and prompts enriched" do
    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssue in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Verify artifacts
    execution2 = @execution.reload
    review_feedback = execution2.artifacts.find_by(artifact_type: :review_feedback)
    retry_context = execution2.artifacts.find_by(artifact_type: :retry_context)

    assert review_feedback, "Expected review_feedback artifact"
    assert_equal score_report.id, review_feedback.parent_artifact_id, "Expected review_feedback to link to score_report"
    assert_includes review_feedback.content, "Issue in app/models/user.rb", "Expected review_feedback to contain original feedback"

    assert retry_context, "Expected retry_context artifact"
    assert_includes retry_context.content, "attempt_1", "Expected retry_context to contain attempt context"
  end

  # =============================================================================
  # AC-9: Console output includes score, threshold, verdict, issues, artifact ID
  # =============================================================================

  test "AC-9: Retry flow executes without errors" do
    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssue in app/models/user.rb",
      metadata: { "score" => 85 }
    )

    # Execute retry_with_context
    # Note: The RetryWithContext tool doesn't output to stdout by default
    # This test verifies the tool executes without errors
    output = capture_output do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: @execution,
        score_report: score_report
      )
    end

    # Verify attempt was incremented
    assert_equal 2, @execution.reload.attempt, "Expected attempt to be incremented to 2"
  end

  # =============================================================================
  # AC-10: PRD content included in retry context
  # =============================================================================

  test "AC-10: PRD content included in retry context" do
    prd_content = <<~PRD
      # Application Requirements

      ## Features
      - User authentication
      - Data persistence

      ## Quality Standards
      - 100% test coverage
      - Zero critical bugs
    PRD

    prd_path = Rails.root.join("tmp", "test_prd_retry.md")
    File.write(prd_path, prd_content)

    begin
      # Create score report
      score_report = Artifact.create!(
        project: @project,
        workflow_run: @workflow_run,
        workflow_execution: @execution,
        created_by: @team,
        artifact_type: :score_report,
        name: "Score Report",
        content: "# Score\n85/100\n\n## Feedback\nIssue in app/models/user.rb",
        metadata: { "score" => 85 }
      )

      # Execute retry_with_context
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: @execution,
        score_report: score_report
      )

      # Verify retry context includes attempt context
      execution2 = @execution.reload
      retry_context = execution2.artifacts.find_by(artifact_type: :retry_context)

      assert retry_context, "Expected retry_context artifact"
      assert_includes retry_context.content, "attempt_1", "Expected retry_context to contain attempt context"
    ensure
      File.delete(prd_path) if File.exist?(prd_path)
    end
  end

  # =============================================================================
  # AC-11: Error handling for missing resources
  # =============================================================================

  test "AC-11: Error handling for missing score report" do
    # Test with nil score report
    assert_raises(NoMethodError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: @execution,
        score_report: nil
      )
    end
  end

  test "AC-11: Error handling for missing execution" do
    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100",
      metadata: { "score" => 85 }
    )

    # Test with nil execution
    assert_raises(NoMethodError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: nil,
        score_report: score_report
      )
    end
  end

  test "AC-11: Error handling for attempt >= max_retries" do
    # Create execution at max attempts
    execution_at_limit = create(:workflow_execution,
                               project: @project,
                               phase: :executing,
                               attempt: 3,
                               task_retry_limit: 3,
                               prd_path: "test_prd.md")

    # Add workflow_run to execution
    execution_at_limit.workflow_runs << @workflow_run

    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution_at_limit,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100",
      metadata: { "score" => 85 }
    )

    # Test that retry_with_context raises precondition error
    assert_raises(Legion::OrchestrationTools::RetryWithContext::PreconditionError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: execution_at_limit,
        score_report: score_report
      )
    end
  end

  test "AC-11: Error handling for score >= threshold" do
    # Create score report with passing score
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n95/100",
      metadata: { "score" => 95 }
    )

    # Test that retry_with_context raises precondition error
    assert_raises(Legion::OrchestrationTools::RetryWithContext::PreconditionError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: @execution,
        score_report: score_report
      )
    end
  end

  # =============================================================================
  # Additional integration tests
  # =============================================================================

  test "integration: Full retry flow with multiple attempts" do
    # First attempt - score below threshold
    score_report1 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 1",
      content: "# Score\n85/100\n\n## Feedback\nFirst issue",
      metadata: { "score" => 85 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report1
    )

    # Verify attempt was incremented
    assert_equal 2, @execution.reload.attempt, "Expected attempt to be incremented to 2"

    # Second attempt - score still below threshold
    execution2 = @execution.reload
    score_report2 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution2,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 2",
      content: "# Score\n88/100\n\n## Feedback\nSecond issue",
      metadata: { "score" => 88 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: execution2,
      score_report: score_report2
    )

    # Verify attempt was incremented
    assert_equal 3, execution2.reload.attempt, "Expected attempt to be incremented to 3"

    # Third attempt - score still below threshold (last retry)
    execution3 = execution2.reload
    score_report3 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution3,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 3",
      content: "# Score\n89/100\n\n## Feedback\nThird issue",
      metadata: { "score" => 89 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: execution3,
      score_report: score_report3
    )

    # Verify attempt was incremented
    assert_equal 4, execution3.reload.attempt, "Expected attempt to be incremented to 4"

    # Fourth attempt - should fail (max retries reached)
    execution4 = execution3.reload
    score_report4 = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: execution4,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report 4",
      content: "# Score\n89/100",
      metadata: { "score" => 89 }
    )

    assert_raises(Legion::OrchestrationTools::RetryWithContext::PreconditionError) do
      Legion::OrchestrationTools::RetryWithContext.call(
        execution: execution4,
        score_report: score_report4
      )
    end
  end

  test "integration: Task reset with retry limit enforcement" do
    # Create a task that has reached retry limit
    task_at_limit = create(:task,
                          project: @project,
                          team_membership: @membership,
                          workflow_run: @workflow_run,
                          workflow_execution: @execution,
                          position: 3,
                          prompt: "Task at retry limit",
                          task_type: :code,
                          status: "failed",
                          retry_count: 3)

    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100\n\n## Feedback\nIssue in task at limit",
      metadata: { "score" => 85 }
    )

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Verify task at limit is marked as permanently failed
    task_at_limit.reload
    assert_equal "failed", task_at_limit.status, "Expected task at limit to be marked as failed"
    assert task_at_limit.metadata["permanently_failed"], "Expected permanently_failed flag to be set"
  end

  test "integration: ConductorJob enqueued with retry_ready trigger" do
    # Create score report
    score_report = Artifact.create!(
      project: @project,
      workflow_run: @workflow_run,
      workflow_execution: @execution,
      created_by: @team,
      artifact_type: :score_report,
      name: "Score Report",
      content: "# Score\n85/100",
      metadata: { "score" => 85 }
    )

    # Count jobs before
    before_count = ActiveJob::Base.queue_adapter.enqueued_jobs.size

    # Execute retry_with_context
    Legion::OrchestrationTools::RetryWithContext.call(
      execution: @execution,
      score_report: score_report
    )

    # Count jobs after
    after_count = ActiveJob::Base.queue_adapter.enqueued_jobs.size

    # Verify ConductorJob was enqueued
    assert_equal before_count + 1, after_count, "Expected ConductorJob to be enqueued"

    # Verify the job has the correct trigger
    conductor_job = ActiveJob::Base.queue_adapter.enqueued_jobs.last
    assert_equal ConductorJob, conductor_job[:job], "Expected ConductorJob to be enqueued"
    assert_equal :retry_ready, conductor_job[:args][1], "Expected trigger to be :retry_ready"
  end

  # =============================================================================
  # Private helper methods
  # =============================================================================

  private

  def capture_output
    output = StringIO.new
    original_stdout = $stdout
    $stdout = output
    yield
    $stdout = original_stdout
    output.string
  end
end
