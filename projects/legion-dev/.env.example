# SmartProxy connection (required for agent dispatch)
# SmartProxy is a Sinatra-based reverse proxy for LLM routing on port 3002
SMART_PROXY_URL=http://192.168.4.253:3001
SMART_PROXY_PORT=3001
SMART_PROXY_HOST=192.168.4.253
SMART_PROXY_TOKEN=<your-smartproxy-token>

# AiderDesk Configuration (optional — only needed when AiderDesk app is running)
# AIDERDESK_URL=http://localhost:24337
# AIDERDESK_USERNAME=admin
# AIDERDESK_PASSWORD=<your-password>
